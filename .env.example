# ─────────────────────────────────────────────────────────────────
# DGK ERP — Environment variables
# Copy to .env and fill in values. .env is gitignored; .env.example is not.
# ─────────────────────────────────────────────────────────────────

# Postgres via Supabase pooler.
#   DATABASE_URL — runtime queries (Session pooler for MVP, Transaction pooler
#   at Vercel deploy; docs/DECISIONS.md).
#   DIRECT_URL   — migrations (always Session pooler, port 5432).
DATABASE_URL=""
DIRECT_URL=""

# NextAuth v5 / Auth.js — generate AUTH_SECRET with: openssl rand -base64 32
AUTH_SECRET="generate-with-openssl-rand-base64-32"
AUTH_URL="http://localhost:3000"

# Supabase client (Storage). Publishable key only — no service role key in app.
NEXT_PUBLIC_SUPABASE_URL=""
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=""

# Public app URL (redirects, absolute links in PDFs / emails).
NEXT_PUBLIC_APP_URL="http://localhost:3000"
